# SyberTriage Environment Configuration
# Copy this file to .env and fill in values

# ── Backend ────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# Anthropic Claude API (optional — platform runs with simulated AI without it)
# When provided, replaces simulated AI with real Claude triage reasoning
ANTHROPIC_API_KEY=your_api_key_here
CLAUDE_MODEL=claude-sonnet-4-6

# Alert simulation settings
ALERT_INTERVAL_MIN_MS=8000     # Minimum delay between new alerts
ALERT_INTERVAL_MAX_MS=15000    # Maximum delay between new alerts
INITIAL_ALERT_COUNT=25         # Alerts loaded on startup

# ── Frontend ────────────────────────────────────────────────
VITE_API_URL=http://localhost:3001
VITE_WS_URL=ws://localhost:3001

# ── Future: Database (optional upgrade from in-memory) ──────
# DATABASE_URL=postgresql://user:password@localhost:5432/sybertriage
# REDIS_URL=redis://localhost:6379
