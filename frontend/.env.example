# ─────────────────────────────────────────────────────────
#  SyberOps Frontend — Environment Variables
# ─────────────────────────────────────────────────────────

# ── Backend URLs (production only) ───────────────────────
# In development these are NOT needed — Vite proxy handles it automatically.
# Set these in your Vercel project environment variables.

# Your Railway backend URL (no trailing slash)
VITE_API_URL=https://syberops-api.up.railway.app

# WebSocket URL for Railway (use wss:// for HTTPS backends)
VITE_WS_URL=wss://syberops-api.up.railway.app
