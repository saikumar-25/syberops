# ─────────────────────────────────────────────────────────
#  SyberOps Backend — Environment Variables
# ─────────────────────────────────────────────────────────

# Server port (Railway sets this automatically)
PORT=3001

# ── Claude AI (Real Agents) ───────────────────────────────
# Get your key from https://console.anthropic.com
# If omitted, the platform falls back to the simulation engine
ANTHROPIC_API_KEY=sk-ant-...

# Claude model to use for AI triage agents
# Recommended: claude-haiku-4-5-20251001 (fast) or claude-sonnet-4-6 (smarter)
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# ── CORS ─────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
# For production: your Vercel deployment URL + custom domain
CORS_ORIGIN=https://syberops.com,https://www.syberops.com,https://syberops-dashboard.vercel.app
